                                    <ui:NumberBox Value="{Binding GameBalances.CollectionObjectHpRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="可采集物体刷新间隔" Width="175" VerticalAlignment="Center" ToolTip="可采集物体刷新的间隔"/>
