                                </DockPanel>
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="杂项" FontWeight="Bold" Margin="0,0,0,3" FontSize="20"/>
                                    <DockPanel>
                                        <TextBlock Text="白天流逝速度" Width="175" VerticalAlignment="Center" ToolTip="白天时间流逝速度"/>
                                        <ui:NumberBox Value="{Binding GameBalances.DayTimeSpeedRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
