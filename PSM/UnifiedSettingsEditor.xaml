                                        <TextBlock Text="工作速度倍率" Width="175" VerticalAlignment="Center" ToolTip="工作速度倍率"/>
                                        <ui:NumberBox Value="{Binding GameBalances.WorkSpeedRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Expander>
                </Border>

                <!-- 4. PvP -->
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="6">
                    <Expander Header="PvP" Margin="10,5,10,5" Padding="5">
                        <StackPanel>
                            <CheckBox x:Name="CheckIsPvP" Content="启用PvP" IsChecked="{Binding Features.bIsPvP, Mode=TwoWay}" ToolTip="启用PvP模式" Margin="0,3,0,3" Checked="IsPvP_CheckedChanged" Unchecked="IsPvP_CheckedChanged" FontWeight="Bold"/>
                            <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Background="#332222" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold" Foreground="#FFCCCC" Text="启用PvP后生效以下变更：" Margin="0,0,0,6"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 玩家之间可以互相造成伤害。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 基地帕鲁将攻击侵入你基地的敌对玩家。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 空中玩家和骑乘帕鲁受到的所有伤害增加。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 玩家对召唤帕鲁和基地帕鲁造成的伤害减少。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 玩家可以访问其他公会拥有的箱子。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 对其他玩家建造的建筑造成的近战伤害减少。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 基地帕鲁将在大范围内攻击敌人。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 基地之间的最小距离增加，你的基地必须与附近基地保持更远距离。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 玩家名称和伤害数值的显示距离发生变化。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 基地受到攻击时会发送通知，战斗期间无法在基地内建造或修理。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 部分武器的射程和伤害已针对PvP进行调整。"/>
                                            <TextBlock FontSize="12" Foreground="#FFCCCC" Text="• 禁用任务。"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#223322" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold" Foreground="#CCFFCC" Text="官方推荐PvP配置（启用PvP时建议设置以下值）：" Margin="0,0,0,6"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 允许分配攻击属性=False，允许分配生命属性=False"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 禁用影响平衡的科技（空涡龙的导弹发射器、唤夜兽的鞍具、钩爪、公会箱等）"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 仅限基地间快速旅行=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 离线后进入睡眠状态=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 允许选择起始位置=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 死亡惩罚=掉落所有物品和队伍中的帕鲁，可拾取其他公会死亡掉落=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 显示其他公会基地边界=False"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 禁止在传送点附近建造=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 公会最大玩家数=4，每个公会最大据点数量=2"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 建筑数量上限(0=无限)=1000"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 公会重新加入冷却(分钟)=60"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 复活冷却时间(秒)=5，复活惩罚时长阈值(秒)=1800，复活惩罚时间倍率=2"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 启用地图显示基地PvP物品数量=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ 启用地图显示玩家PvP物品数量=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃ PvP奖励："/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃   启用PvP击杀额外掉落=True"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃   掉落物品ID=PlayerDropItem（冠军徽章）"/>
                                            <TextBlock FontSize="12" Foreground="#CCFFCC" Text="┃   掉落数量=1"/>
                                        </StackPanel>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="地图显示" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <CheckBox x:Name="CheckDisplayPvPItemNumOnWorldMap_BaseCamp" Content="地图显示基地PvP物品数量" IsChecked="{Binding Features.bDisplayPvPItemNumOnWorldMap_BaseCamp, Mode=TwoWay}" ToolTip="在地图上显示各基地的PvP专属物品数量" Margin="0,3,0,0"/>
                                            <CheckBox x:Name="CheckDisplayPvPItemNumOnWorldMap_Player" Content="地图显示玩家PvP物品数量" IsChecked="{Binding Features.bDisplayPvPItemNumOnWorldMap_Player, Mode=TwoWay}" ToolTip="在地图上显示玩家位置和PvP专属物品数量" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                            <TextBlock Text="公会与防御" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <CheckBox x:Name="CheckEnableDefenseOtherGuildPlayer" Content="防御其他公会玩家" IsChecked="{Binding Features.bEnableDefenseOtherGuildPlayer, Mode=TwoWay}" ToolTip="启用防御其他公会玩家" Margin="0,3,0,0"/>
                                            <CheckBox x:Name="CheckInvisibleOtherGuildBaseCampAreaFX" Content="显示其他公会基地边界" IsChecked="{Binding Features.bInvisibleOtherGuildBaseCampAreaFX, Mode=TwoWay}" ToolTip="显示其他公会基地范围边界" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                            <TextBlock Text="额外掉落" FontWeight="Bold" Margin="0,0,0,3"/>
                                            <DockPanel x:Name="PvPDropItemIdPanel">
                                                <TextBlock Text="PvP击杀额外掉落物品ID" Width="175" VerticalAlignment="Center"/>
                                                <TextBox x:Name="PvPDropItemIdBox" TextChanged="PvPDropItemIdBox_TextChanged" Width="200"/>
                                            </DockPanel>
                                            <DockPanel x:Name="PvPDropItemNumPanel">
                                                <TextBlock Text="PvP击杀额外掉落数量" Width="175" VerticalAlignment="Center" ToolTip="PvP模式下击杀玩家额外掉落物品的数量"/>
                                                <ui:NumberBox Value="{Binding GameBalances.AdditionalDropItemNumWhenPlayerKillingInPvPMode, Mode=TwoWay}" Width="160" SmallChange="1" Maximum="100" Minimum="0" SpinButtonPlacementMode="Inline"/>
                                            </DockPanel>
                                            <CheckBox x:Name="CheckAdditionalPvPDrop" Content="启用PvP击杀额外掉落" IsChecked="{Binding GameBalances.bAdditionalDropItemWhenPlayerKillingInPvPMode, Mode=TwoWay}" ToolTip="是否在PvP启用时掉落特殊物品" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- 5. 禁用科技 -->
                <Border BorderBrush="Black" BorderThickness="1" CornerRadius="6">
                    <Expander Header="禁用科技" Margin="10,5,10,5" Padding="5">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="已选择禁用科技数量：" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TechCountTextBlock" Text="0" VerticalAlignment="Center" FontWeight="Bold"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Text="搜索科技：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox x:Name="TechSearchBox" TextChanged="TechSearchBox_TextChanged"/>
                            </DockPanel>
                            <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding TechItems, ElementName=ThisWindow}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2,1">
                                                <CheckBox.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="300" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </CheckBox.ToolTip>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Expander>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>