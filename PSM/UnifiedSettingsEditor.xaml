                                    <ui:NumberBox Value="{Binding GameBalances.PlayerDamageRateDefense, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="玩家生命值自然回复倍率" Width="175" VerticalAlignment="Center" ToolTip="玩家自然生命恢复倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PlayerAutoHPRegeneRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="玩家睡眠时生命值回复倍率" Width="175" VerticalAlignment="Center" ToolTip="玩家睡眠中生命恢复倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PlayerAutoHpRegeneRateInSleep, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="玩家耐力降低倍率" Width="175" VerticalAlignment="Center" ToolTip="玩家耐力消耗倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PlayerStaminaDecreaceRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="玩家饱腹感降低倍率" Width="175" VerticalAlignment="Center" ToolTip="玩家饥饿速度倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PlayerStomachDecreaceRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                <TextBlock Text="帕鲁" FontWeight="Bold" Margin="0,0,0,3" FontSize="20"/>
                                <CheckBox Content="帕鲁永久死亡" IsChecked="{Binding GameBalances.bPalLost, Mode=TwoWay}" ToolTip="帕鲁死亡时将永久失去该帕鲁" Margin="0,3,0,0"/>
                                <DockPanel>
                                    <TextBlock Text="帕鲁自然生命恢复倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁自然生命恢复倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalAutoHPRegeneRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁睡眠生命恢复倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁睡眠中（帕鲁箱子）生命恢复倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalAutoHpRegeneRateInSleep, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁耐力降低倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁耐力消耗倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalStaminaDecreaceRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁饱腹感降低倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁饥饿速度倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalStomachDecreaceRate, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁攻击伤害倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁造成伤害倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalDamageRateAttack, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁承受伤害倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁承受伤害倍率"/>
                                    <ui:NumberBox Value="{Binding GameBalances.PalDamageRateDefense, Mode=TwoWay}" Width="160" SmallChange="0.1" Maximum="100" Minimum="0.1" NumberFormatter="{StaticResource DecimalFormatter}" SpinButtonPlacementMode="Inline"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="帕鲁出现数量倍率" Width="175" VerticalAlignment="Center" ToolTip="帕鲁出现数量倍率（影响性能）"/>
