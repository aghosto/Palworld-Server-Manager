<Window x:Class="PalworldServerManager.SaveEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="存档编辑器"
        Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WhiteBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="存档文件：" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="FilePathBox" Width="400" IsReadOnly="True"/>
            <Button x:Name="BrowseButton" Content="浏览" Width="80" Margin="8,0,0,0" Click="BrowseButton_Click"/>
            <Button x:Name="ConvertToJsonButton" Content="转为 JSON" Width="100" Margin="8,0,0,0" Click="ConvertToJson_Click"/>
            <Button x:Name="ConvertToSavButton" Content="转为 SAV" Width="100" Margin="8,0,0,0" Click="ConvertToSav_Click"/>
            <Button x:Name="OpenServerSavesButton" Content="打开服务器存档" Width="120" Margin="8,0,0,0" Click="OpenServerSaves_Click"/>
        </StackPanel>

        <!-- Content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ContentBox"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"/>
            <TextBlock x:Name="StatusText"
                       Text="选择一个 .sav 文件开始编辑"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="Gray"
                       FontSize="16"/>
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="2" Margin="0,4,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
