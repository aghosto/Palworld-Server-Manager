<Window x:Class="PalworldServerManager.RestConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PalworldServerManager"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="REST API终端" MinHeight="670" Height="670" MinWidth="830" Width="830" ResizeMode="CanResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Margin="5 5 0 0" Grid.Column="0">
            <GroupBox Header="服务器地址" HorizontalAlignment="Left">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="IP地址：" Width="70" VerticalAlignment="Center"/>
                        <TextBox x:Name="IpAddressBox" Width="110"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="端口：" Width="70" VerticalAlignment="Center"/>
                        <ui:NumberBox x:Name="PortBox" Width="110" SpinButtonPlacementMode="Hidden" Minimum="1" Maximum="65535"/>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="操作" HorizontalAlignment="Left" Margin="0,5,0,0">
                <StackPanel>
                    <Button Content="获取服务器信息" Margin="5" Click="GetInfoButton_Click" Height="30"/>
                    <Button Content="获取玩家列表" Margin="5" Click="GetPlayersButton_Click" Height="30"/>
                    <Button Content="获取服务器指标" Margin="5" Click="GetMetricsButton_Click" Height="30"/>
                    <Button Content="获取服务器设置" Margin="5" Click="GetSettingsButton_Click" Height="30"/>
                    <Button Content="保存世界" Margin="5" Click="SaveWorldButton_Click" Height="30"/>
                    <Button Content="强制停止" Margin="5" Click="ForceStopButton_Click" Height="30"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0 5 5 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <RichTextBox x:Name="RestConsoleOutput"
                             Grid.Row="0"
                             Foreground="LimeGreen"
                             Background="Black"
                             IsReadOnly="True"
                             Height="580"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"/>

                <StackPanel Grid.Row="1" Margin="5">
                    <DockPanel Margin="0,0,0,3">
                        <TextBlock Text="公告消息：" Width="80" VerticalAlignment="Center"/>
                        <TextBox x:Name="AnnounceTextBox" Width="340"/>
                        <Button Content="发送公告" Margin="5,0,0,0" Click="AnnounceButton_Click" Width="80"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,3">
                        <TextBlock Text="玩家ID：" Width="80" VerticalAlignment="Center"/>
                        <TextBox x:Name="PlayerIdTextBox" Width="180"/>
                        <TextBlock Text="原因：" Width="40" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        <TextBox x:Name="ReasonTextBox" Width="120"/>
                        <Button Content="踢出" Margin="5,0,0,0" Click="KickButton_Click" Width="50"/>
                        <Button Content="封禁" Margin="5,0,0,0" Click="BanButton_Click" Width="50"/>
                        <Button Content="解封" Margin="5,0,0,0" Click="UnbanButton_Click" Width="50"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="关服等待(秒)：" Width="100" VerticalAlignment="Center"/>
                        <ui:NumberBox x:Name="ShutdownWaitBox" Width="80" Minimum="1" Maximum="3600" Value="60" SpinButtonPlacementMode="Hidden"/>
                        <Button Content="关闭服务器" Margin="5,0,0,0" Click="ShutdownButton_Click" Width="90"/>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
